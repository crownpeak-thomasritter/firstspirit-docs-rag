# Docker Compose env template for FirstSpirit Docs RAG.
#
# Copy to `deploy/.env` (gitignored) and fill in real values, then run from
# the repo root:
#     docker compose -f deploy/docker-compose.yml up -d --build
#
# Compose reads this file automatically when invoked with the path above.

# ---------------------------------------------------------------------------
# Vector store (Qdrant)
# ---------------------------------------------------------------------------
#
# Local dev: leave both blank. The compose file ships a `qdrant` service and
# defaults QDRANT_URL to `http://qdrant:6333` (no auth, blank API key is
# valid).
#
# Production: point QDRANT_URL at your Qdrant Cloud cluster and set a real
# QDRANT_API_KEY. The bundled `qdrant` service can be left running idle or
# skipped at startup with `--scale qdrant=0`.
#
# Examples:
#   QDRANT_URL=https://<your-cluster>.cloud.qdrant.io
#   QDRANT_API_KEY=<your Qdrant Cloud key>
# QDRANT_URL=
# QDRANT_API_KEY=
# QDRANT_COLLECTION=firstspirit_docs

# ---------------------------------------------------------------------------
# Provider selection (LLM + embeddings)
# ---------------------------------------------------------------------------

# Values: openrouter | openai. Each can be set independently.
# LLM_PROVIDER=openrouter
# EMBEDDING_PROVIDER=openrouter

# Required when LLM_PROVIDER=openrouter or EMBEDDING_PROVIDER=openrouter.
OPENROUTER_API_KEY=

# Required when LLM_PROVIDER=openai or EMBEDDING_PROVIDER=openai.
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# ---------------------------------------------------------------------------
# Model overrides
# ---------------------------------------------------------------------------

# Override the chat model.
# OpenRouter slug example: anthropic/claude-sonnet-4.6 (default)
# OpenAI native example: gpt-4o
# CHAT_MODEL=anthropic/claude-sonnet-4.6

# Override the embedding model.
# OpenRouter slug example: openai/text-embedding-3-small (default)
# OpenAI native example: text-embedding-3-small
# EMBEDDING_MODEL=openai/text-embedding-3-small

# Reasoning effort — "low" / "medium" / "high" on supported models.
# LLM_REASONING_EFFORT=

# ---------------------------------------------------------------------------
# App (optional overrides)
# ---------------------------------------------------------------------------

# Host port the app listens on. Default opens http://localhost:8000.
# APP_HOST_PORT=8000

# RAG knobs — defaults are fine for most use cases.
# RETRIEVAL_EXPANSION_WINDOW=1
# RETRIEVAL_MAX_PER_DOCUMENT=3
# CITATIONS_MAX_COUNT=10
# LLM_TOOLS_ENABLED=true
# LLM_TOOLS_MAX_PER_TURN=6
# DOCUMENT_TOOL_MAX_CHARS=120000
# CATALOG_ENABLED=false
# CATALOG_TIER=standard
# CATALOG_CACHE_TTL_SECONDS=3600

# Polite-crawl identity. Always include a real contact so site owners can
# reach you if the crawler misbehaves.
# CRAWLER_USER_AGENT=FirstSpiritDocsRAG/1.0 (+contact: you@example.com)
# CRAWLER_REQUEST_DELAY_MS=500
# CRAWLER_MAX_RETRIES=4
# CRAWLER_TIMEOUT_SECONDS=30.0
# DEFAULT_SOURCE_TYPE=firstspirit

# CORS origins. When the bundled frontend is served from the same origin
# this is unnecessary; override only if you host the frontend separately.
# CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ---------------------------------------------------------------------------
# Source mounts
# ---------------------------------------------------------------------------

# Directory containing the URL-list markdown file. The default is the
# repo-relative `deploy/sources/` which ships with a placeholder `URL List.md`.
# URL_LIST_HOST_PATH=./sources

# Path on the host to your Obsidian markdown vault. The default mounts the
# committed empty placeholder so compose comes up even without a vault.
# Set this to an absolute path to ingest a real vault.
#
# Windows users: use forward slashes in compose env, e.g.
#   VAULT_HOST_PATH=C:/Users/you/OneDrive/Obsidian/Docs
# VAULT_HOST_PATH=./sources/empty-vault

# When VAULT_HOST_PATH points at a real vault, also uncomment this so the
# backend's vault ingester actually reads it. Leave blank to disable vault
# ingestion entirely.
# SOURCE_VAULT_PATH_IN_CONTAINER=/app/vault
