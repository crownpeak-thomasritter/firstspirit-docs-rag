# FirstSpirit Docs RAG — environment configuration template.
#
# Copy this file to `.env` at the project root and fill in real values. The
# backend's `config.py` walks parent directories of `app/backend/` looking for
# a `.env`, so placement here is correct. Never commit `.env` itself.

# ---------------------------------------------------------------------------
# LLM / embeddings (OpenRouter) — required
# ---------------------------------------------------------------------------

# Authenticates both embeddings (text-embedding-3-small) and chat completions
# (anthropic/claude-sonnet-4.6) against OpenRouter's OpenAI-compatible API.
# Without this the backend boots but every embed/chat call fails.
OPENROUTER_API_KEY=

# Optional override for the chat model (must remain an OpenRouter slug).
# CHAT_MODEL=anthropic/claude-sonnet-4.6

# Optional Anthropic reasoning effort. Empty disables; "low" / "medium" / "high"
# enable extended thinking for supported models. Leave blank unless you know you
# need it — billed input tokens grow noticeably.
# LLM_REASONING_EFFORT=

# ---------------------------------------------------------------------------
# Persistence — required
# ---------------------------------------------------------------------------

# Postgres connection string. The app refuses to start without this.
# Local dev shape: postgresql://docs_rag:<password>@127.0.0.1:5433/docs_rag
DATABASE_URL=

# JWT settings remain in config.py for forward compatibility with the donor's
# auth shape — the pivot has no auth stack wired up, so this is unused today.
# JWT_SECRET=

# ---------------------------------------------------------------------------
# RAG tuning
# ---------------------------------------------------------------------------

# Expand each retrieved chunk by N neighbouring chunks before passing to the LLM.
# RETRIEVAL_EXPANSION_WINDOW=1

# Per-document diversity cap inside a single retrieval response. Stops one
# popular doc from monopolising the top-k.
# RETRIEVAL_MAX_PER_DOCUMENT=3

# How many citation chips the API surfaces per assistant message. Cited chunks
# always survive; this caps the uncited-but-relevant tail.
# CITATIONS_MAX_COUNT=10

# Feature flag for the LLM tool-calling loop. "false" forces the donor's
# legacy single-shot RAG path; default "true" enables search/get_document tools.
# LLM_TOOLS_ENABLED=true

# Hard cap on tool calls the model may issue per user turn (prevents runaway loops).
# LLM_TOOLS_MAX_PER_TURN=6

# Anthropic prompt-cache control: when enabled, the document catalog is
# injected into the system prompt with a cache_control block so repeated
# queries hit the cache. Adds tokens on every request — only worth it for
# high-traffic deployments.
# CATALOG_ENABLED=false
# CATALOG_TIER=standard           # "standard" (~5 min) or "extended" (1 hour)
# CATALOG_CACHE_TTL_SECONDS=3600  # ignored unless CATALOG_TIER=extended

# Cap on characters the `get_document` tool may return in one call. Keeps the
# model from blowing its context window when it pulls a long page wholesale.
# DOCUMENT_TOOL_MAX_CHARS=120000

# ---------------------------------------------------------------------------
# Source ingestion
# ---------------------------------------------------------------------------

# Path to a markdown file containing one URL per line. Blank lines and lines
# starting with '#' are ignored. Markdown link syntax is parsed.
SOURCE_URL_LIST_PATH=./URL List.md

# Path to an Obsidian-style markdown vault. Empty disables the vault ingester;
# only the URL-list pipeline will be available.
SOURCE_VAULT_PATH=

# Crawler identity. Always include a contact so site owners can reach you.
# CRAWLER_USER_AGENT=FirstSpiritDocsRAG/1.0 (+contact: you@example.com)

# Politeness knobs for the URL-list crawler.
# CRAWLER_REQUEST_DELAY_MS=500
# CRAWLER_MAX_RETRIES=4
# CRAWLER_TIMEOUT_SECONDS=30.0

# Source-type tag applied to every ingested document + chunk.
# DEFAULT_SOURCE_TYPE=firstspirit

# ---------------------------------------------------------------------------
# HTTP / CORS
# ---------------------------------------------------------------------------

# Comma-separated origin list. Default permits the Vite dev server only.
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Absolute path to the built frontend bundle (Vite's dist/). When set, FastAPI
# serves index.html + static assets and falls back to index.html for SPA routes.
# FRONTEND_DIST=
