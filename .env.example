# FirstSpirit Docs RAG — environment configuration template.
#
# Copy this file to `.env` at the project root and fill in real values. The
# backend's `config.py` walks parent directories of `app/backend/` looking for
# a `.env`, so placement here is correct. Never commit `.env` itself.

# ---------------------------------------------------------------------------
# Vector store (Qdrant Cloud) — required
# ---------------------------------------------------------------------------

QDRANT_URL=
QDRANT_API_KEY=
# QDRANT_COLLECTION=firstspirit_docs

# ---------------------------------------------------------------------------
# Provider selection (LLM + embeddings)
# ---------------------------------------------------------------------------

# Values: openrouter | openai. Each can be set independently.
# LLM_PROVIDER=openrouter
# EMBEDDING_PROVIDER=openrouter

# Required when LLM_PROVIDER=openrouter or EMBEDDING_PROVIDER=openrouter.
OPENROUTER_API_KEY=

# Required when LLM_PROVIDER=openai or EMBEDDING_PROVIDER=openai.
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# Override the chat model.
# OpenRouter slug example: anthropic/claude-sonnet-4.6 (default)
# OpenAI native example: gpt-4o
# CHAT_MODEL=anthropic/claude-sonnet-4.6

# Override the embedding model.
# OpenRouter slug example: openai/text-embedding-3-small (default)
# OpenAI native example: text-embedding-3-small
# EMBEDDING_MODEL=openai/text-embedding-3-small

# Optional reasoning effort. Empty disables; "low" / "medium" / "high"
# enable extended thinking for supported models.
# LLM_REASONING_EFFORT=

# ---------------------------------------------------------------------------
# Persistence — required
# ---------------------------------------------------------------------------

# SQLite connection string. The app refuses to start without this. The
# data directory is created on first start; `cd app && uv --project backend
# run uvicorn …` resolves the relative path to `app/data/app.db`.
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# JWT settings remain in config.py for forward compatibility with the donor's
# auth shape — the pivot has no auth stack wired up, so this is unused today.
# JWT_SECRET=

# ---------------------------------------------------------------------------
# RAG tuning
# ---------------------------------------------------------------------------

# Expand each retrieved chunk by N neighbouring chunks before passing to the LLM.
# RETRIEVAL_EXPANSION_WINDOW=1

# Per-document diversity cap inside a single retrieval response.
# RETRIEVAL_MAX_PER_DOCUMENT=3

# How many citation chips the API surfaces per assistant message.
# CITATIONS_MAX_COUNT=10

# Feature flag for the LLM tool-calling loop.
# LLM_TOOLS_ENABLED=true

# Hard cap on tool calls the model may issue per user turn.
# LLM_TOOLS_MAX_PER_TURN=6

# Document catalog injection into the system prompt. Only meaningful for
# OpenRouter chat (the Anthropic cache_control block is stripped when
# LLM_PROVIDER=openai — OpenAI native has automatic prompt caching).
# CATALOG_ENABLED=false
# CATALOG_TIER=standard           # "standard" (~5 min) or "extended" (1 hour)
# CATALOG_CACHE_TTL_SECONDS=3600  # ignored unless CATALOG_TIER=extended

# Cap on characters the `get_document` tool may return in one call.
# DOCUMENT_TOOL_MAX_CHARS=120000

# ---------------------------------------------------------------------------
# Source ingestion
# ---------------------------------------------------------------------------

# Path to a markdown file containing one URL per line. Blank lines and lines
# starting with '#' are ignored. Markdown link syntax is parsed.
SOURCE_URL_LIST_PATH=./URL List.md

# Path to an Obsidian-style markdown vault. Empty disables the vault ingester.
SOURCE_VAULT_PATH=

# Crawler identity.
# CRAWLER_USER_AGENT=FirstSpiritDocsRAG/1.0 (+contact: you@example.com)

# Politeness knobs for the URL-list crawler.
# CRAWLER_REQUEST_DELAY_MS=500
# CRAWLER_MAX_RETRIES=4
# CRAWLER_TIMEOUT_SECONDS=30.0

# Source-type tag applied to every ingested document + chunk.
# DEFAULT_SOURCE_TYPE=firstspirit

# ---------------------------------------------------------------------------
# HTTP / CORS
# ---------------------------------------------------------------------------

# Comma-separated origin list. Default permits the Vite dev server only.
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Absolute path to the built frontend bundle (Vite's dist/).
# FRONTEND_DIST=
